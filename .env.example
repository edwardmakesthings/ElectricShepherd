# ElectricShepherd local runtime configuration template.
# Copy to .env on your machine and keep .env out of git.

# Optional explicit env file override for runtime scripts
# ESHEPHERD_ENV_FILE=/absolute/path/to/custom.env

# Required for standalone runtime scripts
MEMPALACE_MCP_URL=http://localhost:8093/mcp

# Optional auth for MCP endpoints
MEMPALACE_MCP_API_KEY=
MEMPALACE_MCP_AUTH_HEADER=Authorization
MEMPALACE_MCP_AUTH_SCHEME=
MEMPALACE_MCP_BEARER_TOKEN=
MEMPALACE_MCP_HEADERS_JSON=

# Optional gateway-specific tool namespace override
MEMGRAPH_TOOL_PREFIX=mempalace_

# Optional capture-specific tool prefix override
ESHEPHERD_MEMRAW_TOOL_PREFIX=mempalace_

# Optional plugin/runtime toggles
ESHEPHERD_MEMCORE_REINJECT_ENABLED=true
ESHEPHERD_MEMCORE_REINJECT_ON_COMPACT=true
ESHEPHERD_MEMCORE_REINJECT_ON_IDLE=true
ESHEPHERD_MEMCORE_REINJECT_ON_START=true
ESHEPHERD_ALLOWED_SYNTH_WRITERS=dreamer,dream-consolidator
ESHEPHERD_MEMRAW_VERIFY_ENABLED=true
ESHEPHERD_MEMRAW_CAPTURE_CMD=