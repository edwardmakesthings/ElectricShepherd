# ElectricShepherd local runtime configuration template.
# Copy to .env on your machine and keep .env out of git.

# Optional explicit env file override for runtime scripts
# ESHEPHERD_ENV_FILE=/absolute/path/to/custom.env

# Required for standalone runtime scripts
MEMPALACE_MCP_URL=http://localhost:8093/mcp

# Optional auth for MCP endpoints
MEMPALACE_MCP_API_KEY=
MEMPALACE_MCP_AUTH_HEADER=Authorization
MEMPALACE_MCP_AUTH_SCHEME=
MEMPALACE_MCP_BEARER_TOKEN=
MEMPALACE_MCP_HEADERS_JSON=

# Integration tests use MEMPALACE_MCP_URL (above). The MCP endpoint must expose
# the full tool surface, including lineage graph tools.

# Optional gateway-specific tool namespace override
MEMGRAPH_TOOL_PREFIX=mempalace_

# Optional capture-specific tool prefix override
ESHEPHERD_SOURCE_CAPTURE_TOOL_PREFIX=mempalace_
# Optional source-capture dedupe gate (default false keeps source transcript append-only)
ESHEPHERD_SOURCE_CAPTURE_DEDUP_ENABLED=false

# Optional plugin/runtime toggles
ESHEPHERD_MEMCORE_REINJECT_ENABLED=true
ESHEPHERD_MEMCORE_REINJECT_ON_COMPACT=true
ESHEPHERD_MEMCORE_REINJECT_ON_IDLE=true
ESHEPHERD_MEMCORE_REINJECT_ON_START=true
# Retry guard applies to all agents/modes by default; set false to disable globally.
ESHEPHERD_RETRY_ENABLED=true
# Optional explicit opt-out lists (CSV, case-insensitive).
# Example: ESHEPHERD_RETRY_DISABLED_AGENTS=dream-mapper,dream-auditor
ESHEPHERD_RETRY_DISABLED_AGENTS=
# Example: ESHEPHERD_RETRY_DISABLED_MODES=ask
ESHEPHERD_RETRY_DISABLED_MODES=
ESHEPHERD_ALLOWED_CONSOLIDATION_WRITERS=dreamer,dream-consolidator
ESHEPHERD_SOURCE_CAPTURE_VERIFY_ENABLED=true
ESHEPHERD_SOURCE_CAPTURE_CMD=

# Automatic consolidation (OPT-IN). When enabled, the plugin runs background memory
# consolidation on its own after the session goes quiet, after enough new turns,
# or on compaction. It writes to memory without prompting — leave disabled unless
# you understand the triggers (see QUICKSTART.md section 3f).
ESHEPHERD_AUTO_CONSOLIDATION_ENABLED=false
ESHEPHERD_AUTO_CONSOLIDATION_ON_IDLE=true
ESHEPHERD_AUTO_CONSOLIDATION_ON_COMPACT=true
# Quiet period (ms) after idle before an idle-triggered run; reset by any new message.
ESHEPHERD_AUTO_CONSOLIDATION_IDLE_DELAY_MS=120000
# New assistant turns that force a run regardless of idle.
ESHEPHERD_AUTO_CONSOLIDATION_MESSAGE_THRESHOLD=12
# Minimum gap (ms) between auto-consolidation runs.
ESHEPHERD_AUTO_CONSOLIDATION_COOLDOWN_MS=600000
# Watchdog: kill a run that exceeds this (ms); also the cross-process lock staleness window.
ESHEPHERD_AUTO_CONSOLIDATION_TIMEOUT_MS=300000
# Upper bound on per-session tracking entries before the oldest are evicted (prevents leaks in long-lived processes).
ESHEPHERD_AUTO_CONSOLIDATION_MAX_TRACKED_SESSIONS=512
# Optional override for the command auto-consolidation runs (default: deterministic cadence execute).
ESHEPHERD_AUTO_CONSOLIDATION_CMD=
# Set to 1 to bypass the shared consolidation lock (testing/automation only; allows concurrent runs).
ESHEPHERD_CONSOLIDATION_LOCK_DISABLED=

# Blocking-subprocess ceilings (ms) so a hung capture/loader script can't freeze the session.
ESHEPHERD_SOURCE_CAPTURE_TIMEOUT_MS=20000
ESHEPHERD_MEMCORE_LOADER_TIMEOUT_MS=15000